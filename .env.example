# Cloudflare Pages Environment Variables
# For Local Development (using wrangler): Save as .dev.vars
# For Production: Add these in Cloudflare Dashboard -> Settings -> Environment Variables

BAGIBAGI_API_KEY=your_secret_api_key_here
BAGIBAGI_MERCHANT_CODE=your_merchant_code_here
BAGIBAGI_WEBHOOK_URL=https://pixenzebooth.com/api/payment-callback

VITE_SENTRY_DSN=your_sentry_dsn_here

# === Google Drive Upload (via Google Apps Script) ===
# Deploy DriveUploader.gs as Web App, paste URL below (comma-separated for multi-node)
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# === Secure License Validation (Server-side) ===
# Supabase URL (same as VITE_SUPABASE_URL)
SUPABASE_URL=https://your-project.supabase.co
# Supabase service_role key (NEVER use VITE_ prefix — server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# HMAC signing secret for license responses (generate: openssl rand -hex 32)
LICENSE_SIGNING_SECRET=your_random_secret_here
